# Base de datos
DATABASE_URL=postgresql://user:password@localhost:5432/it_knowledge_base

# Autenticación
JWT_SECRET=cambiar-por-secret-seguro-minimo-64-caracteres
JWT_EXPIRES_IN=8h

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Gmail — Integración Backups
# Requiere App Password: Google Account → Seguridad → Contraseñas de aplicación
GMAIL_EMAIL=tu-cuenta@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Cron de sincronización automática (default: cada 4 horas)
GMAIL_SYNC_CRON=0 */4 * * *
# Días hacia atrás que se buscan en cada sync (default: 90)
GMAIL_SYNC_DAYS=90
