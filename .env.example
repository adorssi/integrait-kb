# Base de datos (credenciales internas de Docker)
DB_USER=integrait
DB_PASSWORD=cambiar-por-password-seguro

# Autenticación JWT
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar-por-secret-seguro-minimo-64-caracteres

# Gmail — Integración Backups
GMAIL_EMAIL=tu-cuenta@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_SYNC_CRON=0 */4 * * *
GMAIL_SYNC_DAYS=90

# Cifrado de credenciales (NVRs, cámaras, etc.)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CRÍTICO: respaldar esta clave — si se pierde, las credenciales cifradas son irrecuperables
ENCRYPTION_KEY=
